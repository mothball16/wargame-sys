{
  "name": "rocket-artillery",
  "tree": {
    "$className": "DataModel",

    "ReplicatedStorage": {
      "m_Shared": {
        "$className": "Folder",
        "_Utilities": {"$path": "src/ReplicatedStorage/_Utilities"},
        "_Main": {
          "$path": "src/ReplicatedStorage/_Main",
          "$properties": {
            "Attributes": {
              "mOS_FrameworkFolder": {"Bool": true},
              "mOS_BootstrapperLoadOrder": {"Float64": -999}
            }
          }

        },
        "Doors": {
          "$path": "src/ReplicatedStorage/Doors",
          "$properties": {
            "Attributes": {
              "mOS_FrameworkFolder": {"Bool": true}
            }
          }
        },
        "Artillery": {
          "$path": "src/ReplicatedStorage/Artillery",
          "$properties": {
            "Attributes": {
              "mOS_FrameworkFolder": {"Bool": true}
            }
          }
        }
      }
    },

    "ServerScriptService": {
      "m_Server": {
        "$className": "Folder",
        "_Main": {
          "$path": "src/ServerScriptService/_Main",
          "$properties": {
            "Attributes": {
              "mOS_FrameworkFolder": {"Bool": true},
              "mOS_BootstrapperLoadOrder": {"Float64": -999}

            }
          }
        },
        "Doors": {
          "$path": "src/ServerScriptService/Doors",
          "$properties": {
            "Attributes": {
              "mOS_FrameworkFolder": {"Bool": true}
              
            }
          }
        },
        "Artillery": {
          "$path": "src/ServerScriptService/Artillery",
          "$properties": {
            "Attributes": {
              "mOS_FrameworkFolder": {"Bool": true}
            }
          }
        }
      }
    },

    "StarterPlayer": {
      "StarterPlayerScripts": {
        "m_Client": {
          "$className": "Folder",
          "_Main": {
            "$path": "src/StarterPlayerScripts/_Main",
            "$properties": {
              "Attributes": {
                "mOS_FrameworkFolder": {"Bool": true},
                "mOS_BootstrapperLoadOrder": {"Float64": -999}
              }
            }
          },
          "Doors": {
            "$path": "src/StarterPlayerScripts/Doors",
            "$properties": {
              "Attributes": {
                "mOS_FrameworkFolder": {"Bool": true}
              }
            }
          },
          "Artillery": {
            "$path": "src/StarterPlayerScripts/Artillery",
            "$properties": {
              "Attributes": {
                "mOS_FrameworkFolder": {"Bool": true}
              }
            }
          }
        }
      }
    },

    "Workspace": {
      "$properties": {
        "FilteringEnabled": true
      }
    },
    "Lighting": {
      "$properties": {
        "Ambient": [
          0,
          0,
          0
        ],
        "Brightness": 2,
        "GlobalShadows": true,
        "Outlines": false,
        "Technology": "Voxel"
      }
    },
    "SoundService": {
      "$properties": {
        "RespectFilteringEnabled": true
      }
    }
  }
}
